# BryanF Access - environment variables
# Copy this file as .env.local and fill in real values.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare Turnstile. In development the app allows a missing secret.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Public WhatsApp CTA, country code included, without + or spaces.
NEXT_PUBLIC_WHATSAPP_NUMBER=52XXXXXXXXXX

# Admin-only password login. Clients still use magic links.
ADMIN_EMAIL=bryanf@bryanfdesign.com.mx
ADMIN_ACCESS_PASSWORD=change-this-long-admin-password
ADMIN_SESSION_SECRET=change-this-random-64-char-secret
CREDENTIALS_ENCRYPTION_KEY=change-this-different-random-64-char-secret

# Optional Upstash Redis for production rate limiting.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
